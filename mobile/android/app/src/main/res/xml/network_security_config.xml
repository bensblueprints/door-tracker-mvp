<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (HTTP, not HTTPS) is allowed ONLY for local development hosts:
  10.0.2.2 (the Android emulator's alias for the host machine's localhost),
  and localhost/127.0.0.1 for testing against a server running on the phone
  itself. Any other domain — i.e. any real self-hosted Door Tracker server a
  rep actually connects to in production — is NOT covered by this override,
  so the platform's default cleartext-traffic block still applies to it and
  a real deployment must be served over HTTPS (e.g. behind a reverse proxy
  with a TLS certificate, as documented in the main Door Tracker README).
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="false">10.0.2.2</domain>
    <domain includeSubdomains="false">localhost</domain>
    <domain includeSubdomains="false">127.0.0.1</domain>
  </domain-config>
</network-security-config>
