# Door Tracker configuration — copy to .env and edit

# Port the web app listens on
PORT=5374

# Admin password for the manager dashboard (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location
DB_PATH=./data/door-tracker.db

# Public base URL of this install — used for links inside CSV exports, etc.
BASE_URL=

# Allow the /api/simulate demo endpoint (generates a fake day of pings for a
# rep so you can see the dashboard working before wiring up real phones).
# Set to "false" in a real production deploy once you have live reps.
ALLOW_SIMULATE=true
